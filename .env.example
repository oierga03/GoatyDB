# =============================================================================
# GoatyDB — Variables de entorno
# =============================================================================
# Copia este archivo a `.env` y ajusta los valores.
#   cp .env.example .env
#
# DATABASE_URL: cadena de conexión de PostgreSQL.
#
# Opción A — PostgreSQL local vía Docker Compose (ver docker-compose.yml):
#   El servicio expone el puerto 5432 con estas credenciales por defecto.
DATABASE_URL="postgresql://goaty:goaty@localhost:5432/goatydb?schema=public"
#
# Opción B — PostgreSQL externo (Neon, Supabase, Railway, RDS, etc.):
#   Sustituye la URL de arriba por la que te dé tu proveedor. Ejemplo:
#   DATABASE_URL="postgresql://usuario:password@host.proveedor.com:5432/basedatos?schema=public&sslmode=require"
